{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": "google",
  "parserOptions": {
    "ecmaVersion": 12
  },
  "rules": {
    "quotes": ["error", "double"],
    "object-curly-spacing": ["error", "always"],
    "max-len": ["error", { "code": 160 }],
    "new-cap": "off",
    "require-jsdoc": "off",
    "indent": ["error", 2],
    "camelcase": "off",
    "guard-for-in": "off",
    "valid-jsdoc": "off",
    "operator-linebreak": "off",
    "comma-dangle": "off"
  }
}
